<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Fina — Personal Finance Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0e0f11;
    --bg2: #15171a;
    --bg3: #1c1e23;
    --bg4: #23262d;
    --border: rgba(255,255,255,0.07);
    --border2: rgba(255,255,255,0.12);
    --text: #f0f0f0;
    --text2: #9a9da6;
    --text3: #5a5d66;
    --accent: #7fba9c;
    --accent2: #3d8a62;
    --accent-bg: rgba(127,186,156,0.08);
    --red: #e06b6b;
    --red-bg: rgba(224,107,107,0.08);
    --amber: #e8a848;
    --amber-bg: rgba(232,168,72,0.08);
    --blue: #6b9de8;
    --blue-bg: rgba(107,157,232,0.08);
    --purple: #a882e0;
    --r: 12px;
    --r-sm: 8px;
    --font-head: 'Syne', sans-serif;
    --font-body: 'DM Sans', sans-serif;
    --sidebar: 240px;
  }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    font-size: 14px;
    line-height: 1.6;
  }

  /* SIDEBAR */
  .sidebar {
    width: var(--sidebar);
    background: var(--bg2);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 28px 16px;
    position: fixed;
    top: 0; left: 0; bottom: 0;
    z-index: 10;
  }
  .logo {
    font-family: var(--font-head);
    font-size: 22px;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: -0.5px;
    margin-bottom: 8px;
    padding: 0 8px;
  }
  .logo span { color: var(--text3); font-weight: 400; font-size: 11px; display: block; letter-spacing: 0.5px; text-transform: uppercase; }
  .nav { display: flex; flex-direction: column; gap: 2px; margin-top: 32px; flex: 1; }
  .nav-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 10px; border-radius: var(--r-sm);
    color: var(--text2); font-size: 13.5px; cursor: pointer;
    transition: all 0.15s; font-weight: 400; border: 1px solid transparent;
  }
  .nav-item:hover { background: var(--bg3); color: var(--text); }
  .nav-item.active { background: var(--accent-bg); color: var(--accent); border-color: rgba(127,186,156,0.15); }
  .nav-item svg { width: 17px; height: 17px; flex-shrink: 0; }
  .nav-section { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--text3); padding: 14px 10px 4px; font-weight: 500; }
  .sidebar-footer { border-top: 1px solid var(--border); padding-top: 16px; }
  .budget-progress { padding: 12px; background: var(--bg3); border-radius: var(--r-sm); }
  .budget-progress label { font-size: 11px; color: var(--text2); text-transform: uppercase; letter-spacing: 0.5px; display: flex; justify-content: space-between; }
  .progress-bar { height: 4px; background: var(--bg4); border-radius: 999px; margin-top: 8px; overflow: hidden; }
  .progress-fill { height: 100%; border-radius: 999px; background: var(--accent); transition: width 0.6s ease; }

  /* MAIN */
  .main { margin-left: var(--sidebar); flex: 1; display: flex; flex-direction: column; }
  .topbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 32px; border-bottom: 1px solid var(--border);
    background: var(--bg); position: sticky; top: 0; z-index: 5;
  }
  .topbar-title { font-family: var(--font-head); font-size: 18px; font-weight: 700; }
  .topbar-date { font-size: 12px; color: var(--text3); }
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 16px; border-radius: var(--r-sm);
    font-family: var(--font-body); font-size: 13px; font-weight: 500;
    cursor: pointer; border: none; transition: all 0.15s;
  }
  .btn-primary { background: var(--accent); color: #0e1a14; }
  .btn-primary:hover { background: #8fcfad; }
  .btn-ghost { background: var(--bg3); color: var(--text2); border: 1px solid var(--border2); }
  .btn-ghost:hover { color: var(--text); background: var(--bg4); }
  .btn svg { width: 15px; height: 15px; }

  /* CONTENT AREA */
  .content { padding: 28px 32px; flex: 1; }

  /* VIEWS */
  .view { display: none; }
  .view.active { display: block; }

  /* STAT CARDS */
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 24px; }
  .stat-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--r); padding: 18px 20px;
    transition: border-color 0.15s;
  }
  .stat-card:hover { border-color: var(--border2); }
  .stat-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.7px; color: var(--text3); margin-bottom: 8px; }
  .stat-value { font-family: var(--font-head); font-size: 24px; font-weight: 700; }
  .stat-change { font-size: 11px; margin-top: 4px; color: var(--text3); }
  .stat-change.up { color: var(--accent); }
  .stat-change.down { color: var(--red); }
  .stat-icon { width: 32px; height: 32px; border-radius: var(--r-sm); display: flex; align-items: center; justify-content: center; margin-bottom: 12px; }

  /* GRID LAYOUTS */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .three-col { display: grid; grid-template-columns: 1.6fr 1fr; gap: 16px; }

  /* CARDS */
  .card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--r); padding: 22px 24px;
  }
  .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
  .card-title { font-family: var(--font-head); font-size: 14px; font-weight: 700; letter-spacing: -0.2px; }
  .card-sub { font-size: 11px; color: var(--text3); margin-top: 2px; }

  /* CHART BARS */
  .bar-chart { display: flex; align-items: flex-end; gap: 8px; height: 140px; }
  .bar-col { display: flex; flex-direction: column; align-items: center; gap: 6px; flex: 1; }
  .bar-wrap { flex: 1; width: 100%; display: flex; align-items: flex-end; }
  .bar {
    width: 100%; border-radius: 4px 4px 0 0;
    transition: height 0.6s cubic-bezier(0.34,1.56,0.64,1);
    position: relative; cursor: pointer;
    min-height: 4px;
  }
  .bar:hover { opacity: 0.8; }
  .bar-label { font-size: 10px; color: var(--text3); }
  .bar-val { font-size: 10px; font-weight: 500; }

  /* CATEGORY PILLS */
  .cat-list { display: flex; flex-direction: column; gap: 10px; }
  .cat-item { display: flex; align-items: center; gap: 10px; }
  .cat-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .cat-name { flex: 1; font-size: 13px; }
  .cat-bar-wrap { width: 80px; height: 4px; background: var(--bg4); border-radius: 999px; overflow: hidden; }
  .cat-bar-fill { height: 100%; border-radius: 999px; }
  .cat-amt { font-size: 12px; font-weight: 500; min-width: 52px; text-align: right; }
  .cat-pct { font-size: 11px; color: var(--text3); min-width: 32px; text-align: right; }

  /* TRANSACTION LIST */
  .tx-list { display: flex; flex-direction: column; gap: 2px; }
  .tx-item {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 12px; border-radius: var(--r-sm);
    transition: background 0.12s; cursor: default;
  }
  .tx-item:hover { background: var(--bg3); }
  .tx-icon { width: 34px; height: 34px; border-radius: var(--r-sm); display: flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }
  .tx-info { flex: 1; min-width: 0; }
  .tx-name { font-size: 13px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .tx-meta { font-size: 11px; color: var(--text3); }
  .tx-amt { font-size: 13.5px; font-weight: 600; text-align: right; }
  .tx-amt.income { color: var(--accent); }
  .tx-amt.expense { color: var(--red); }
  .tx-del { opacity: 0; background: none; border: none; color: var(--text3); cursor: pointer; padding: 2px 4px; border-radius: 4px; transition: all 0.12s; }
  .tx-item:hover .tx-del { opacity: 1; }
  .tx-del:hover { background: var(--red-bg); color: var(--red); }

  /* MODAL */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.7);
    display: flex; align-items: center; justify-content: center;
    z-index: 100; opacity: 0; pointer-events: none; transition: opacity 0.2s;
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal {
    background: var(--bg2); border: 1px solid var(--border2);
    border-radius: calc(var(--r) + 4px); padding: 28px; width: 420px;
    transform: translateY(12px); transition: transform 0.25s cubic-bezier(0.34,1.2,0.64,1);
  }
  .modal-overlay.open .modal { transform: translateY(0); }
  .modal-title { font-family: var(--font-head); font-size: 16px; font-weight: 700; margin-bottom: 20px; }
  .field { margin-bottom: 14px; }
  .field label { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.6px; color: var(--text3); margin-bottom: 6px; }
  .field input, .field select {
    width: 100%; background: var(--bg3); border: 1px solid var(--border2);
    border-radius: var(--r-sm); padding: 9px 12px; color: var(--text);
    font-family: var(--font-body); font-size: 13.5px; outline: none;
    transition: border-color 0.15s;
  }
  .field input:focus, .field select:focus { border-color: var(--accent); }
  .field select option { background: var(--bg3); }
  .type-toggle { display: flex; gap: 6px; }
  .type-btn {
    flex: 1; padding: 8px; border-radius: var(--r-sm); border: 1px solid var(--border2);
    background: var(--bg3); color: var(--text2); font-size: 13px;
    cursor: pointer; font-family: var(--font-body); transition: all 0.15s;
  }
  .type-btn.active-income { background: var(--accent-bg); border-color: var(--accent); color: var(--accent); }
  .type-btn.active-expense { background: var(--red-bg); border-color: var(--red); color: var(--red); }
  .modal-actions { display: flex; gap: 8px; margin-top: 20px; }
  .modal-actions .btn { flex: 1; justify-content: center; }

  /* BUDGET PAGE */
  .budget-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .budget-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--r); padding: 18px 20px;
  }
  .budget-card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
  .budget-cat { font-size: 13px; font-weight: 500; display: flex; align-items: center; gap: 8px; }
  .budget-amounts { font-size: 11px; color: var(--text3); }
  .budget-amounts span { font-weight: 500; color: var(--text2); }
  .budget-bar-track { height: 6px; background: var(--bg4); border-radius: 999px; overflow: hidden; }
  .budget-bar-prog { height: 100%; border-radius: 999px; transition: width 0.6s ease; }
  .budget-footer { display: flex; justify-content: space-between; margin-top: 8px; font-size: 11px; color: var(--text3); }
  .budget-footer .remaining { font-weight: 500; }
  .budget-footer .remaining.over { color: var(--red); }
  .budget-footer .remaining.ok { color: var(--accent); }

  /* INSIGHTS */
  .insight-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--r); padding: 18px 20px; display: flex; gap: 14px; align-items: flex-start;
  }
  .insight-icon { font-size: 20px; line-height: 1; }
  .insight-title { font-size: 13px; font-weight: 500; margin-bottom: 3px; }
  .insight-desc { font-size: 12px; color: var(--text2); line-height: 1.5; }

  /* TAGS */
  .tag { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 500; }
  .tag-green { background: var(--accent-bg); color: var(--accent); }
  .tag-red { background: var(--red-bg); color: var(--red); }
  .tag-amber { background: var(--amber-bg); color: var(--amber); }
  .tag-blue { background: var(--blue-bg); color: var(--blue); }

  /* EMPTY STATE */
  .empty { text-align: center; padding: 40px 20px; color: var(--text3); }
  .empty-icon { font-size: 36px; margin-bottom: 12px; }
  .empty p { font-size: 13px; }

  /* DONUT */
  .donut-wrap { display: flex; align-items: center; gap: 20px; }
  .donut-legend { display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .donut-legend-item { display: flex; align-items: center; gap: 8px; font-size: 12px; }
  .donut-legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .donut-legend-name { flex: 1; color: var(--text2); }
  .donut-legend-val { font-weight: 500; }

  /* SAVINGS TRACKER */
  .saving-goal { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r); padding: 18px 20px; }
  .saving-title { font-size: 13px; font-weight: 500; margin-bottom: 4px; }
  .saving-target { font-size: 11px; color: var(--text3); margin-bottom: 12px; }
  .saving-amount { font-family: var(--font-head); font-size: 22px; font-weight: 700; margin-bottom: 10px; }
  .saving-amount span { font-size: 13px; font-weight: 400; color: var(--text3); }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--bg4); border-radius: 999px; }

  /* RESPONSIVE */
  @media (max-width: 1100px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .three-col { grid-template-columns: 1fr; }
  }
  @media (max-width: 800px) {
    .sidebar { width: 60px; }
    .sidebar .logo span, .sidebar .nav-item span, .sidebar-footer { display: none; }
    .main { margin-left: 60px; }
  }

  /* TOAST */
  .toast {
    position: fixed; bottom: 24px; right: 24px;
    background: var(--bg3); border: 1px solid var(--border2);
    color: var(--text); border-radius: var(--r-sm); padding: 10px 16px;
    font-size: 13px; z-index: 200; opacity: 0;
    transform: translateY(8px); transition: all 0.25s;
  }
  .toast.show { opacity: 1; transform: translateY(0); }

  /* ANIMATIONS */
  @keyframes fade-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .view.active > * { animation: fade-in 0.3s ease forwards; }
</style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="logo">fina<span>Smart Finance Tracker</span></div>
  <nav class="nav">
    <div class="nav-section">Overview</div>
    <div class="nav-item active" data-view="dashboard" onclick="switchView('dashboard',this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
      <span>Dashboard</span>
    </div>
    <div class="nav-item" data-view="transactions" onclick="switchView('transactions',this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 12H3M21 6H3M21 18H3"/></svg>
      <span>Transactions</span>
    </div>
    <div class="nav-section">Planning</div>
    <div class="nav-item" data-view="budget" onclick="switchView('budget',this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l2.5 2.5"/></svg>
      <span>Budget</span>
    </div>
    <div class="nav-item" data-view="insights" onclick="switchView('insights',this)">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      <span>Insights</span>
    </div>
  </nav>
  <div class="sidebar-footer">
    <div class="budget-progress">
      <label>Monthly Budget <span id="sb-pct">0%</span></label>
      <div class="progress-bar"><div class="progress-fill" id="sb-bar" style="width:0%"></div></div>
    </div>
  </div>
</aside>

<!-- MAIN -->
<main class="main">
  <div class="topbar">
    <div>
      <div class="topbar-title" id="page-title">Dashboard</div>
      <div class="topbar-date" id="page-date"></div>
    </div>
    <button class="btn btn-primary" onclick="openModal()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Transaction
    </button>
  </div>

  <div class="content">

    <!-- DASHBOARD VIEW -->
    <div class="view active" id="view-dashboard">
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon" style="background:var(--accent-bg)">💰</div>
          <div class="stat-label">Total Balance</div>
          <div class="stat-value" id="stat-balance">₹0</div>
          <div class="stat-change" id="stat-balance-change">—</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon" style="background:var(--accent-bg)">📈</div>
          <div class="stat-label">Monthly Income</div>
          <div class="stat-value" id="stat-income">₹0</div>
          <div class="stat-change up" id="stat-income-change">This month</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon" style="background:var(--red-bg)">📉</div>
          <div class="stat-label">Monthly Expenses</div>
          <div class="stat-value" id="stat-expenses">₹0</div>
          <div class="stat-change down" id="stat-exp-change">This month</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon" style="background:var(--blue-bg)">🏦</div>
          <div class="stat-label">Savings Rate</div>
          <div class="stat-value" id="stat-savings">0%</div>
          <div class="stat-change" id="stat-savings-change">of income saved</div>
        </div>
      </div>

      <div class="three-col" style="margin-bottom:16px;">
        <div class="card">
          <div class="card-header">
            <div><div class="card-title">Spending This Month</div><div class="card-sub">Daily expenses overview</div></div>
          </div>
          <div class="bar-chart" id="bar-chart"></div>
        </div>
        <div class="card">
          <div class="card-header"><div class="card-title">By Category</div></div>
          <div class="donut-wrap">
            <svg id="donut-svg" width="110" height="110" viewBox="0 0 110 110"></svg>
            <div class="donut-legend" id="donut-legend"></div>
          </div>
        </div>
      </div>

      <div class="two-col">
        <div class="card">
          <div class="card-header">
            <div class="card-title">Recent Transactions</div>
            <button class="btn btn-ghost" style="padding:5px 10px;font-size:12px;" onclick="switchView('transactions', document.querySelector('[data-view=transactions]'))">View all</button>
          </div>
          <div class="tx-list" id="recent-tx-list"></div>
        </div>
        <div class="card">
          <div class="card-header"><div class="card-title">Top Categories</div></div>
          <div class="cat-list" id="cat-list-dash"></div>
        </div>
      </div>
    </div>

    <!-- TRANSACTIONS VIEW -->
    <div class="view" id="view-transactions">
      <div class="card" style="margin-bottom:16px;">
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
          <input type="text" id="search-input" placeholder="Search transactions…" style="flex:1;background:var(--bg3);border:1px solid var(--border2);border-radius:var(--r-sm);padding:8px 12px;color:var(--text);font-family:var(--font-body);font-size:13px;outline:none;min-width:180px;" oninput="renderTransactions()" />
          <select id="filter-type" style="background:var(--bg3);border:1px solid var(--border2);border-radius:var(--r-sm);padding:8px 12px;color:var(--text);font-family:var(--font-body);font-size:13px;outline:none;" onchange="renderTransactions()">
            <option value="all">All Types</option>
            <option value="income">Income</option>
            <option value="expense">Expenses</option>
          </select>
          <select id="filter-cat" style="background:var(--bg3);border:1px solid var(--border2);border-radius:var(--r-sm);padding:8px 12px;color:var(--text);font-family:var(--font-body);font-size:13px;outline:none;" onchange="renderTransactions()">
            <option value="all">All Categories</option>
          </select>
        </div>
      </div>
      <div class="card">
        <div class="tx-list" id="full-tx-list"></div>
        <div class="empty" id="tx-empty" style="display:none;">
          <div class="empty-icon">🔍</div>
          <p>No transactions found</p>
        </div>
      </div>
    </div>

    <!-- BUDGET VIEW -->
    <div class="view" id="view-budget">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;">
        <div>
          <div style="font-family:var(--font-head);font-size:15px;font-weight:700;">Monthly Budget</div>
          <div style="font-size:12px;color:var(--text3);">Track spending against your limits</div>
        </div>
        <button class="btn btn-ghost" onclick="openBudgetModal()">Edit Budgets</button>
      </div>
      <div class="budget-grid" id="budget-grid"></div>

      <div style="margin-top:24px;">
        <div style="font-family:var(--font-head);font-size:14px;font-weight:700;margin-bottom:14px;">Savings Goals</div>
        <div class="budget-grid" id="savings-goals-grid"></div>
      </div>
    </div>

    <!-- INSIGHTS VIEW -->
    <div class="view" id="view-insights">
      <div style="display:grid;gap:12px;margin-bottom:20px;" id="insights-list"></div>
      <div class="two-col">
        <div class="card">
          <div class="card-header"><div class="card-title">Monthly Trend</div></div>
          <div class="bar-chart" id="trend-chart" style="height:160px;"></div>
        </div>
        <div class="card">
          <div class="card-header"><div class="card-title">Income vs Expenses</div></div>
          <div id="income-exp-chart"></div>
        </div>
      </div>
    </div>

  </div>
</main>

