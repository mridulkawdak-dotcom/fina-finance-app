      <label>Date</label>
      <input type="date" id="tx-date" />
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeModal()">Cancel</button>
      <button class="btn btn-primary" onclick="addTransaction()">Add Transaction</button>
    </div>
