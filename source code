</div>

<!-- BUDGET EDIT MODAL -->
<div class="modal-overlay" id="budget-modal" onclick="e=>e.target===this&&closeBudgetModal()">
  <div class="modal" onclick="event.stopPropagation()" style="width:460px;">
    <div class="modal-title">Set Monthly Budgets</div>
    <div id="budget-fields"></div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeBudgetModal()">Cancel</button>
      <button class="btn btn-primary" onclick="saveBudgets()">Save Budgets</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ========== STATE ==========
const STORAGE_KEY = 'fina_data_v2';
let state = {
  transactions: [],
  budgets: { Food: 8000, Transport: 3000, Shopping: 5000, Health: 2000, Entertainment: 2000, Bills: 4000, Education: 1000, Other: 2000 },
  txType: 'expense'
};

const CAT_COLORS = {
  Food: '#7fba9c', Transport: '#6b9de8', Shopping: '#a882e0',
  Health: '#e06b6b', Entertainment: '#e8a848', Bills: '#5cb8b8',
  Education: '#d4a96a', Salary: '#7fba9c', Freelance: '#6b9de8',
  Investment: '#a882e0', Other: '#888'
};
const CAT_EMOJI = {
  Food:'🍔', Transport:'🚗', Shopping:'🛍️', Health:'💊', Entertainment:'🎬',
  Bills:'🏠', Education:'📚', Salary:'💼', Freelance:'💻', Investment:'📊', Other:'📦'
};

function loadState() {
  try { const d = localStorage.getItem(STORAGE_KEY); if(d) state = JSON.parse(d); } catch(e){}
  if (!state.txType) state.txType = 'expense';
}
function saveState() { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }

// ========== SEED DATA ==========
function seedData() {
  if (state.transactions.length > 0) return;
  const now = new Date();
  const seeds = [
    {name:'Monthly Salary', amount:55000, type:'income', category:'Salary', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 1))},
    {name:'Grocery - Big Bazaar', amount:2800, type:'expense', category:'Food', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 3))},
    {name:'Metro Card Recharge', amount:500, type:'expense', category:'Transport', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 4))},
    {name:'Netflix Subscription', amount:499, type:'expense', category:'Entertainment', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 5))},
    {name:'Electricity Bill', amount:1800, type:'expense', category:'Bills', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 6))},
    {name:'Freelance Project', amount:12000, type:'income', category:'Freelance', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 8))},
    {name:'Restaurant - Dinner', amount:1200, type:'expense', category:'Food', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 9))},
    {name:'Ola Cabs', amount:340, type:'expense', category:'Transport', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 10))},
    {name:'Amazon Shopping', amount:3200, type:'expense', category:'Shopping', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 12))},
    {name:'Gym Membership', amount:1500, type:'expense', category:'Health', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 13))},
    {name:'Udemy Course', amount:799, type:'expense', category:'Education', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 15))},
    {name:'Swiggy Orders', amount:2100, type:'expense', category:'Food', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 16))},
    {name:'Petrol', amount:900, type:'expense', category:'Transport', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 18))},
    {name:'Mobile Recharge', amount:299, type:'expense', category:'Bills', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 19))},
    {name:'Movie Tickets', amount:600, type:'expense', category:'Entertainment', date:fmtDate(new Date(now.getFullYear(), now.getMonth(), 20))},
  ];
  seeds.forEach(s => state.transactions.push({...s, id: Date.now() + Math.random()}));
  saveState();
}

function fmtDate(d) {
  return d.toISOString().split('T')[0];
}

// ========== NAVIGATION ==========
function switchView(id, el) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('view-' + id).classList.add('active');
  if(el) el.classList.add('active');
  const titles = {dashboard:'Dashboard', transactions:'Transactions', budget:'Budget Planner', insights:'Insights'};
  document.getElementById('page-title').textContent = titles[id] || id;
  renderAll();
}

// ========== COMPUTATIONS ==========
function getMonthTxs() {
  const now = new Date();
  return state.transactions.filter(t => {
    const d = new Date(t.date);
    return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
  });
}
function getIncome(txs) { return txs.filter(t=>t.type==='income').reduce((s,t)=>s+t.amount,0); }
function getExpenses(txs) { return txs.filter(t=>t.type==='expense').reduce((s,t)=>s+t.amount,0); }

function getCategoryTotals(txs) {
  const map = {};
  txs.filter(t=>t.type==='expense').forEach(t => { map[t.category] = (map[t.category]||0) + t.amount; });
  return Object.entries(map).sort((a,b)=>b[1]-a[1]);
}

function fmt(n) {
  if(n >= 100000) return '₹' + (n/100000).toFixed(1) + 'L';
  if(n >= 1000) return '₹' + (n/1000).toFixed(1) + 'K';
  return '₹' + Math.round(n).toLocaleString('en-IN');
}
function fmtFull(n) { return '₹' + Math.round(n).toLocaleString('en-IN'); }

// ========== RENDER ALL ==========
function renderAll() {
  renderStats();
  renderBarChart();
  renderDonut();
  renderRecentTx();
  renderCategoryList();
  renderTransactions();
  renderBudget();
  renderInsights();
  renderSidebarProgress();
}

// ========== STATS ==========
function renderStats() {
  const month = getMonthTxs();
  const income = getIncome(month);
  const expenses = getExpenses(month);
  const balance = getIncome(state.transactions) - getExpenses(state.transactions);
  const savings = income > 0 ? ((income - expenses) / income * 100) : 0;

  document.getElementById('stat-balance').textContent = fmtFull(balance);
  document.getElementById('stat-balance-change').textContent = balance >= 0 ? '▲ Positive balance' : '▼ Negative balance';
  document.getElementById('stat-balance-change').className = 'stat-change ' + (balance >= 0 ? 'up' : 'down');

  document.getElementById('stat-income').textContent = fmtFull(income);
  document.getElementById('stat-expenses').textContent = fmtFull(expenses);
  document.getElementById('stat-savings').textContent = Math.round(savings) + '%';

  const sc = document.getElementById('stat-savings-change');
  sc.textContent = savings >= 20 ? '🟢 Healthy savings rate' : savings > 0 ? '🟡 Could save more' : '🔴 Spending exceeds income';
  sc.className = 'stat-change ' + (savings >= 20 ? 'up' : savings > 0 ? '' : 'down');
}

// ========== SIDEBAR PROGRESS ==========
function renderSidebarProgress() {
  const month = getMonthTxs();
  const totalBudget = Object.values(state.budgets).reduce((s,v)=>s+v,0);
  const spent = getExpenses(month);
  const pct = totalBudget > 0 ? Math.min(100, Math.round(spent/totalBudget*100)) : 0;
  document.getElementById('sb-pct').textContent = pct + '%';
  const fill = document.getElementById('sb-bar');
  fill.style.width = pct + '%';
  fill.style.background = pct > 90 ? 'var(--red)' : pct > 70 ? 'var(--amber)' : 'var(--accent)';
}

// ========== BAR CHART (Daily spending) ==========
function renderBarChart() {
  const now = new Date();
  const days = new Date(now.getFullYear(), now.getMonth()+1, 0).getDate();
  const daily = Array(days).fill(0);
  getMonthTxs().filter(t=>t.type==='expense').forEach(t => {
    const day = new Date(t.date).getDate() - 1;
    if(day >= 0 && day < days) daily[day] += t.amount;
  });

  const max = Math.max(...daily, 1);
  const el = document.getElementById('bar-chart');
  const weeks = [];
  for(let i=0;i<days;i+=7) weeks.push(daily.slice(i,i+7).reduce((s,v)=>s+v,0));
  const wmax = Math.max(...weeks, 1);

  el.innerHTML = weeks.map((w,i) => `
    <div class="bar-col">
      <div class="bar-val" style="color:${w===Math.max(...weeks)?'var(--accent)':'var(--text3)'}">${fmt(w)}</div>
      <div class="bar-wrap">
        <div class="bar" style="background:${w===Math.max(...weeks)?'var(--accent)':'var(--bg4)'};height:${Math.round(w/wmax*100)}%;width:100%;"></div>
      </div>
      <div class="bar-label">Wk ${i+1}</div>
    </div>
  `).join('');
}

// ========== DONUT CHART ==========
function renderDonut() {
  const month = getMonthTxs();
  const cats = getCategoryTotals(month).slice(0,5);
  const total = cats.reduce((s,[,v])=>s+v,0);
  const svg = document.getElementById('donut-svg');
  const legend = document.getElementById('donut-legend');

  if(!total) { svg.innerHTML = '<circle cx="55" cy="55" r="36" fill="none" stroke="#23262d" stroke-width="16"/>'; legend.innerHTML='<span style="color:var(--text3);font-size:12px;">No expense data</span>'; return; }

  const cx=55, cy=55, r=36, sw=16;
  let angle = -Math.PI/2;
  let paths = '';
  cats.forEach(([cat, val]) => {
    const slice = (val/total) * Math.PI * 2;
    const x1=cx+r*Math.cos(angle), y1=cy+r*Math.sin(angle);
    angle += slice;
    const x2=cx+r*Math.cos(angle), y2=cy+r*Math.sin(angle);
    const large = slice > Math.PI ? 1 : 0;
    paths += `<path d="M ${cx} ${cy} L ${x1} ${y1} A ${r} ${r} 0 ${large} 1 ${x2} ${y2} Z" fill="${CAT_COLORS[cat]||'#888'}" opacity="0.85"/>`;
  });
  svg.innerHTML = paths + `<circle cx="${cx}" cy="${cy}" r="${r-sw/2}" fill="var(--bg2)"/>`;

  legend.innerHTML = cats.map(([cat,val]) => `
    <div class="donut-legend-item">
      <div class="donut-legend-dot" style="background:${CAT_COLORS[cat]||'#888'}"></div>
      <span class="donut-legend-name">${cat}</span>
      <span class="donut-legend-val">${Math.round(val/total*100)}%</span>
    </div>
  `).join('');
}

// ========== RECENT TRANSACTIONS ==========
function renderRecentTx() {
  const recent = [...state.transactions].sort((a,b)=>new Date(b.date)-new Date(a.date)).slice(0,6);
  const el = document.getElementById('recent-tx-list');
  if(!recent.length) { el.innerHTML = '<div class="empty"><div class="empty-icon">💸</div><p>No transactions yet. Add one!</p></div>'; return; }
  el.innerHTML = recent.map(t => txHTML(t)).join('');
}

function txHTML(t) {
  const color = CAT_COLORS[t.category] || '#888';
  const sign = t.type === 'income' ? '+' : '-';
  const date = new Date(t.date).toLocaleDateString('en-IN', {day:'numeric',month:'short'});
  return `
    <div class="tx-item">
      <div class="tx-icon" style="background:${color}22">${CAT_EMOJI[t.category]||'💳'}</div>
      <div class="tx-info">
        <div class="tx-name">${escHtml(t.name)}</div>
        <div class="tx-meta">${t.category} · ${date}</div>
      </div>
      <div class="tx-amt ${t.type}">${sign}${fmtFull(t.amount)}</div>
      <button class="tx-del" onclick="deleteTx('${t.id}')" title="Delete">✕</button>
    </div>`;
}

function escHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// ========== FULL TRANSACTIONS ==========
function renderTransactions() {
  const search = (document.getElementById('search-input')?.value||'').toLowerCase();
  const typeF = document.getElementById('filter-type')?.value||'all';
  const catF = document.getElementById('filter-cat')?.value||'all';

  // populate category filter
  const catSel = document.getElementById('filter-cat');
  const cats = [...new Set(state.transactions.map(t=>t.category))];
  const curCat = catSel.value;
  catSel.innerHTML = '<option value="all">All Categories</option>' + cats.map(c=>`<option value="${c}" ${c===curCat?'selected':''}>${c}</option>`).join('');

  let txs = [...state.transactions].sort((a,b)=>new Date(b.date)-new Date(a.date));
  if(search) txs = txs.filter(t=>t.name.toLowerCase().includes(search)||t.category.toLowerCase().includes(search));
  if(typeF!=='all') txs = txs.filter(t=>t.type===typeF);
  if(catF!=='all') txs = txs.filter(t=>t.category===catF);

  const el = document.getElementById('full-tx-list');
  const empty = document.getElementById('tx-empty');
  if(!txs.length) { el.innerHTML=''; empty.style.display='block'; return; }
  empty.style.display='none';
  el.innerHTML = txs.map(t=>txHTML(t)).join('');
}

function deleteTx(id) {
  state.transactions = state.transactions.filter(t=>String(t.id)!==String(id));
  saveState();
  renderAll();
  showToast('Transaction deleted');
}

// ========== CATEGORY LIST ==========
function renderCategoryList() {
  const month = getMonthTxs();
  const cats = getCategoryTotals(month).slice(0,5);
  const total = cats.reduce((s,[,v])=>s+v,0)||1;
  const el = document.getElementById('cat-list-dash');
  if(!cats.length) { el.innerHTML='<div style="color:var(--text3);font-size:13px;">No expenses this month</div>'; return; }
  el.innerHTML = cats.map(([cat,val])=>`
    <div class="cat-item">
      <div class="cat-dot" style="background:${CAT_COLORS[cat]||'#888'}"></div>
      <div class="cat-name">${cat}</div>
      <div class="cat-bar-wrap"><div class="cat-bar-fill" style="width:${Math.round(val/total*100)}%;background:${CAT_COLORS[cat]||'#888'}"></div></div>
      <div class="cat-amt">${fmt(val)}</div>
      <div class="cat-pct">${Math.round(val/total*100)}%</div>
    </div>
  `).join('');
}

// ========== BUDGET ==========
function renderBudget() {
  const month = getMonthTxs();
  const catSpend = {};
  month.filter(t=>t.type==='expense').forEach(t=>{catSpend[t.category]=(catSpend[t.category]||0)+t.amount;});

  const expCats = ['Food','Transport','Shopping','Health','Entertainment','Bills','Education','Other'];
  const el = document.getElementById('budget-grid');
  el.innerHTML = expCats.map(cat => {
    const budget = state.budgets[cat]||0;
    const spent = catSpend[cat]||0;
    const pct = budget>0 ? Math.min(100,Math.round(spent/budget*100)) : 0;
    const remaining = budget - spent;
    const color = pct>90?'var(--red)':pct>70?'var(--amber)':'var(--accent)';
    return `
      <div class="budget-card">
        <div class="budget-card-header">
          <div class="budget-cat"><span>${CAT_EMOJI[cat]}</span>${cat}</div>
          <span class="tag ${pct>90?'tag-red':pct>70?'tag-amber':'tag-green'}">${pct}%</span>
        </div>
        <div class="budget-amounts">${fmtFull(spent)} <span>/ ${fmtFull(budget)}</span></div>
        <div class="budget-bar-track" style="margin-top:10px;"><div class="budget-bar-prog" style="width:${pct}%;background:${color}"></div></div>
        <div class="budget-footer">
          <span>${pct}% used</span>
          <span class="remaining ${remaining<0?'over':'ok'}">${remaining<0?'Over by '+fmtFull(-remaining):'₹'+Math.round(remaining).toLocaleString('en-IN')+' left'}</span>
        </div>
      </div>`;
  }).join('');

  // Savings goals
  const income = getIncome(month);
  const expenses = getExpenses(month);
  const saved = Math.max(0, income - expenses);
  const goals = [
    {name:'Emergency Fund', target:100000, saved: Math.round(saved*0.4), icon:'🏦'},
    {name:'Vacation Fund', target:50000, saved: Math.round(saved*0.2), icon:'✈️'},
    {name:'Gadget Upgrade', target:25000, saved: Math.round(saved*0.15), icon:'💻'},
  ];
  const sg = document.getElementById('savings-goals-grid');
  sg.innerHTML = goals.map(g=>{
    const pct = Math.min(100, Math.round(g.saved/g.target*100));
    return `
      <div class="budget-card">
        <div class="budget-card-header">
          <div class="budget-cat">${g.icon} ${g.name}</div>
          <span class="tag tag-blue">${pct}%</span>
        </div>
        <div class="saving-amount">${fmtFull(g.saved)} <span>of ${fmtFull(g.target)}</span></div>
        <div class="budget-bar-track"><div class="budget-bar-prog" style="width:${pct}%;background:var(--blue)"></div></div>
        <div class="budget-footer"><span>Goal: ${fmtFull(g.target)}</span><span class="remaining ok">${fmtFull(g.target-g.saved)} to go</span></div>
      </div>`;
  }).join('');
}

// ========== INSIGHTS ==========
function renderInsights() {
  const month = getMonthTxs();
  const income = getIncome(month);
  const expenses = getExpenses(month);
  const savings = income > 0 ? (income-expenses)/income*100 : 0;
  const cats = getCategoryTotals(month);
  const topCat = cats[0];

  const insights = [];
  if(savings >= 20) insights.push({icon:'🎉', title:'Great savings rate!', desc:`You're saving ${Math.round(savings)}% of your income this month. Financial experts recommend at least 20%.`, type:'green'});
  else if(savings > 0) insights.push({icon:'⚠️', title:'Low savings rate', desc:`You're saving only ${Math.round(savings)}% of your income. Try to cut down discretionary spending.`, type:'amber'});
  else if(income > 0) insights.push({icon:'🚨', title:'Overspending alert!', desc:`Your expenses (${fmtFull(expenses)}) exceed your income (${fmtFull(income)}) this month.`, type:'red'});

  if(topCat) {
    const catPct = Math.round(topCat[1]/expenses*100);
    if(catPct > 40) insights.push({icon:'🔍', title:`High ${topCat[0]} spend`, desc:`${topCat[0]} accounts for ${catPct}% of your expenses (${fmtFull(topCat[1])}). Consider reviewing this category.`, type:'amber'});
  }

  const budgetBreach = Object.entries(state.budgets).filter(([cat,limit])=>{
    const spent = month.filter(t=>t.type==='expense'&&t.category===cat).reduce((s,t)=>s+t.amount,0);
    return spent > limit;
  });
  if(budgetBreach.length) insights.push({icon:'💸', title:`${budgetBreach.length} budget(s) exceeded`, desc:`${budgetBreach.map(([c])=>c).join(', ')} went over budget this month.`, type:'red'});

  if(!insights.length) insights.push({icon:'✅', title:'All looking good!', desc:'No major financial concerns this month. Keep up the good work!', type:'green'});

  const typeColor = {green:'var(--accent)',amber:'var(--amber)',red:'var(--red)'};
  const typeBg = {green:'var(--accent-bg)',amber:'var(--amber-bg)',red:'var(--red-bg)'};

  document.getElementById('insights-list').innerHTML = insights.map(i=>`
    <div class="insight-card" style="border-left:3px solid ${typeColor[i.type]}">
      <div class="insight-icon">${i.icon}</div>
      <div><div class="insight-title">${i.title}</div><div class="insight-desc">${i.desc}</div></div>
    </div>
  `).join('');

  // Trend chart (last 4 months)
  const now = new Date();
  const months = [];
  for(let i=3;i>=0;i--){
    const d = new Date(now.getFullYear(), now.getMonth()-i, 1);
    const label = d.toLocaleString('en-IN',{month:'short'});
    const txs = state.transactions.filter(t=>{const td=new Date(t.date);return td.getMonth()===d.getMonth()&&td.getFullYear()===d.getFullYear();});
    months.push({label, expenses:getExpenses(txs), income:getIncome(txs)});
  }
  const maxVal = Math.max(...months.map(m=>Math.max(m.income,m.expenses)),1);
  document.getElementById('trend-chart').innerHTML = `<div class="bar-chart" style="height:160px;">${months.map(m=>`
    <div class="bar-col">
      <div class="bar-val" style="color:var(--text3)">${fmt(m.expenses)}</div>
      <div class="bar-wrap" style="gap:2px;display:flex;flex-direction:row;align-items:flex-end;">
        <div style="width:45%;background:var(--accent);border-radius:3px 3px 0 0;height:${Math.round(m.income/maxVal*100)}%;min-height:4px;"></div>
        <div style="width:45%;background:var(--red);border-radius:3px 3px 0 0;height:${Math.round(m.expenses/maxVal*100)}%;min-height:4px;"></div>
      </div>
      <div class="bar-label">${m.label}</div>
    </div>
  `).join('')}</div><div style="display:flex;gap:16px;margin-top:10px;font-size:11px;color:var(--text3);"><span><span style="display:inline-block;width:8px;height:8px;background:var(--accent);border-radius:2px;margin-right:4px;"></span>Income</span><span><span style="display:inline-block;width:8px;height:8px;background:var(--red);border-radius:2px;margin-right:4px;"></span>Expenses</span></div>`;

  // Income vs Expenses summary
  document.getElementById('income-exp-chart').innerHTML = `
    <div style="display:flex;flex-direction:column;gap:12px;margin-top:4px;">
      <div>
        <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:6px;"><span style="color:var(--text2)">Income</span><span style="color:var(--accent);font-weight:600">${fmtFull(income)}</span></div>
        <div style="height:8px;background:var(--bg4);border-radius:999px;overflow:hidden;"><div style="height:100%;width:100%;background:var(--accent);border-radius:999px;"></div></div>
      </div>
      <div>
        <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:6px;"><span style="color:var(--text2)">Expenses</span><span style="color:var(--red);font-weight:600">${fmtFull(expenses)}</span></div>
        <div style="height:8px;background:var(--bg4);border-radius:999px;overflow:hidden;"><div style="height:100%;width:${income>0?Math.round(expenses/income*100):0}%;background:var(--red);border-radius:999px;transition:width 0.6s;"></div></div>
      </div>
      <div style="border-top:1px solid var(--border);padding-top:12px;">
        <div style="display:flex;justify-content:space-between;font-size:13px;"><span style="color:var(--text2)">Net Savings</span><span style="color:${income-expenses>=0?'var(--accent)':'var(--red)'};font-weight:600;font-family:var(--font-head);">${fmtFull(Math.abs(income-expenses))} ${income-expenses>=0?'saved':'deficit'}</span></div>
      </div>
    </div>`;
}

// ========== MODAL ==========
function openModal() {
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('tx-date').value = today;
  document.getElementById('tx-name').value = '';
  document.getElementById('tx-amount').value = '';
  document.getElementById('tx-modal').classList.add('open');
  setTimeout(()=>document.getElementById('tx-name').focus(),200);
}
function closeModal() { document.getElementById('tx-modal').classList.remove('open'); }

function setType(type) {
  state.txType = type;
  document.getElementById('type-expense').className = 'type-btn' + (type==='expense'?' active-expense':'');
  document.getElementById('type-income').className = 'type-btn' + (type==='income'?' active-income':'');
  const catSel = document.getElementById('tx-category');
  if(type==='income') {
    catSel.innerHTML = '<option value="Salary">💼 Salary</option><option value="Freelance">💻 Freelance</option><option value="Investment">📊 Investment</option><option value="Other">📦 Other</option>';
  } else {
    catSel.innerHTML = '<option value="Food">🍔 Food & Dining</option><option value="Transport">🚗 Transport</option><option value="Shopping">🛍️ Shopping</option><option value="Health">💊 Health</option><option value="Entertainment">🎬 Entertainment</option><option value="Bills">🏠 Bills & Utilities</option><option value="Education">📚 Education</option><option value="Other">📦 Other</option>';
  }
}

function addTransaction() {
  const name = document.getElementById('tx-name').value.trim();
  const amount = parseFloat(document.getElementById('tx-amount').value);
  const category = document.getElementById('tx-category').value;
  const date = document.getElementById('tx-date').value;

  if(!name) { document.getElementById('tx-name').focus(); showToast('Please enter a description'); return; }
  if(!amount || amount <= 0) { document.getElementById('tx-amount').focus(); showToast('Please enter a valid amount'); return; }
  if(!date) { showToast('Please select a date'); return; }

  state.transactions.push({ id: Date.now(), name, amount, type: state.txType, category, date });
  saveState();
  closeModal();
  renderAll();
  showToast('Transaction added! ✓');
}

// ========== BUDGET MODAL ==========
function openBudgetModal() {
  const cats = ['Food','Transport','Shopping','Health','Entertainment','Bills','Education','Other'];
  document.getElementById('budget-fields').innerHTML = cats.map(cat=>`
    <div class="field" style="display:flex;align-items:center;gap:10px;">
      <label style="min-width:120px;margin:0;text-transform:none;font-size:13px;color:var(--text2);">${CAT_EMOJI[cat]} ${cat}</label>
      <input type="number" id="budget-${cat}" value="${state.budgets[cat]||0}" min="0" style="flex:1;" placeholder="0" />
    </div>
  `).join('');
  document.getElementById('budget-modal').classList.add('open');
}
function closeBudgetModal() { document.getElementById('budget-modal').classList.remove('open'); }
function saveBudgets() {
  const cats = ['Food','Transport','Shopping','Health','Entertainment','Bills','Education','Other'];
  cats.forEach(cat => { const v = parseFloat(document.getElementById('budget-'+cat)?.value)||0; state.budgets[cat]=v; });
  saveState();
  closeBudgetModal();
  renderAll();
  showToast('Budgets updated! ✓');
}

// ========== TOAST ==========
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2500);
}

// ========== KEYBOARD ==========
document.addEventListener('keydown', e => {
  if(e.key==='Escape') { closeModal(); closeBudgetModal(); }
  if(e.key==='n' && !e.ctrlKey && !e.metaKey && document.activeElement===document.body) openModal();
});

// ========== INIT ==========
document.getElementById('page-date').textContent = new Date().toLocaleDateString('en-IN', {weekday:'long', year:'numeric', month:'long', day:'numeric'});
loadState();
seedData();
renderAll();
</script>
</body>
</html>
