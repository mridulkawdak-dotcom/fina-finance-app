      <div class="type-toggle">
        <button class="type-btn active-expense" id="type-expense" onclick="setType('expense')">📉 Expense</button>
        <button class="type-btn" id="type-income" onclick="setType('income')">📈 Income</button>
      </div>
    </div>
    <div class="field">
      <label>Description</label>
      <input type="text" id="tx-name" placeholder="e.g. Grocery shopping" />
    </div>
    <div class="field">
      <label>Amount (₹)</label>
      <input type="number" id="tx-amount" placeholder="0.00" min="0" step="0.01" />
    </div>
    <div class="field">
      <label>Category</label>
      <select id="tx-category">
        <option value="Food">🍔 Food & Dining</option>
        <option value="Transport">🚗 Transport</option>
        <option value="Shopping">🛍️ Shopping</option>
        <option value="Health">💊 Health</option>
        <option value="Entertainment">🎬 Entertainment</option>
        <option value="Bills">🏠 Bills & Utilities</option>
        <option value="Education">📚 Education</option>
        <option value="Salary">💼 Salary</option>
        <option value="Freelance">💻 Freelance</option>
        <option value="Investment">📊 Investment</option>
        <option value="Other">📦 Other</option>
      </select>
    </div>
